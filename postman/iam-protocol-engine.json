{
  "info": {
    "name": "IAM Protocol Engine",
    "description": "OAuth 2.0 (Phase 2), OIDC (Phase 3), Token Lifecycle (Phase 4), Admin UI (Phase 5). Auth Code+PKCE, Client Credentials, Refresh Rotation with family binding, Token Introspection (RFC 7662), Token Revocation (RFC 7009), OIDC Discovery (RFC 8414), JWKS (RFC 7517), ID Token (RS256), /userinfo, Admin UI (React+Vite+MUI), Login Flow, Admin API (/admin/clients, /admin/audit).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "description": "API Gateway base URL"
    },
    {
      "key": "client_id",
      "value": "test-client",
      "description": "OAuth client ID — register via SQL in README"
    },
    {
      "key": "client_secret",
      "value": "test-secret",
      "description": "OAuth client secret"
    },
    {
      "key": "redirect_uri",
      "value": "http://localhost:9000/callback",
      "description": "Must exactly match redirect_uri registered for client"
    },
    {
      "key": "code_verifier",
      "value": "dBjftJeZ4CVP-mB92K27uhbUJU1p1r_wW1gFWFOEjXk",
      "description": "RFC 7636 Appendix B test vector: 43-char random"
    },
    {
      "key": "client_secret_basic",
      "value": "dGVzdC1jbGllbnQ6dGVzdC1zZWNyZXQ=",
      "description": "base64(test-client:test-secret) for Basic auth header"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health",
            "description": "Application health — no auth required"
          }
        },
        {
          "name": "Demo Resource Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health",
            "description": "Demo resource health — no auth required"
          }
        }
      ]
    },
    {
      "name": "OAuth 2.0",
      "item": [
        {
          "name": "Authorize (Auth Code + PKCE)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/oauth2/authorize?client_id={{client_id}}&redirect_uri={{redirect_uri}}&response_type=code&scope=openid%20profile%20email&state=xyz&code_challenge=E9Melhoa2OwvFrEMTJguCHaoeK1t8URWbuGJSstw-cM&code_challenge_method=S256&subject=user1",
              "host": ["{{baseUrl}}"],
              "path": ["oauth2", "authorize"],
              "query": [
                { "key": "client_id", "value": "{{client_id}}", "description": "OAuth client ID" },
                { "key": "redirect_uri", "value": "{{redirect_uri}}", "description": "Must exactly match registered redirect_uri" },
                { "key": "response_type", "value": "code", "description": "Authorization Code flow" },
                { "key": "scope", "value": "openid profile email", "description": "Requested scopes" },
                { "key": "state", "value": "xyz", "description": "CSRF protection state — echoed in redirect" },
                { "key": "code_challenge", "value": "E9Melhoa2OwvFrEMTJguCHaoeK1t8URWbuGJSstw-cM", "description": "S256 PKCE challenge = BASE64URL(SHA256(code_verifier))" },
                { "key": "code_challenge_method", "value": "S256", "description": "PKCE method — S256 only" },
                { "key": "subject", "value": "user1", "description": "Authenticated user identifier (Phase 5 login will handle auth)" }
              ]
            },
            "description": "RFC 6749 §4.1 + RFC 7636. Returns 302 redirect with ?code=...&state=... Extract code from the redirect URL."
          }
        },
        {
          "name": "Token (Auth Code Exchange)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/oauth2/token",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "authorization_code", "description": "RFC 6749 §4.1.1" },
                { "key": "code", "value": "AUTH_CODE_FROM_AUTHORIZE", "description": "Code from /oauth2/authorize redirect" },
                { "key": "code_verifier", "value": "{{code_verifier}}", "description": "Original PKCE verifier — must match code_challenge" },
                { "key": "redirect_uri", "value": "{{redirect_uri}}", "description": "Must match original request" },
                { "key": "client_id", "value": "{{client_id}}", "description": "" }
              ]
            },
            "description": "RFC 6749 §4.1.3. Exchange code for access_token + refresh_token. PKCE code_verifier is validated server-side."
          }
        },
        {
          "name": "Token (Client Credentials)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/oauth2/token",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" },
              { "key": "Authorization", "value": "Basic {{client_secret_basic}}", "description": "RFC 6749 §2.3.1 Basic auth — base64(client_id:client_secret)" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "client_credentials", "description": "RFC 6749 §4.2.1" },
                { "key": "client_secret", "value": "{{client_secret}}", "description": "Required when not using Basic auth header" },
                { "key": "scope", "value": "openid profile email", "description": "Space-separated scopes — limited to client's allowed_scopes" }
              ]
            },
            "description": "RFC 6749 §4.2. Machine-to-machine token. No user subject. Returns access_token only (no refresh_token)."
          }
        },
        {
          "name": "Token (Refresh Rotation)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/oauth2/token",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "refresh_token", "description": "RFC 6749 §6" },
                { "key": "refresh_token", "value": "REFRESH_TOKEN_FROM_PREVIOUS_RESPONSE", "description": "The refresh token — old token is revoked on use" },
                { "key": "client_id", "value": "{{client_id}}", "description": "" }
              ]
            },
            "description": "RFC 6749 §6. Rotating refresh token. Old token is atomically revoked on reuse. Returns new access_token + new refresh_token."
          }
        }
      ]
    },
    {
      "name": "Demo Resource (Protected API)",
      "item": [
        {
          "name": "Protected Resource (no token → 401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/resource",
            "description": "Protected endpoint. Missing token returns 401."
          }
        },
        {
          "name": "Protected Resource (valid token → 200)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/resource",
            "header": [
              { "key": "Authorization", "value": "Bearer ACCESS_TOKEN", "description": "Valid access token from /oauth2/token" }
            ],
            "description": "Validates Bearer token against DB (jti lookup). Returns 200 + token claims if valid."
          }
        }
      ]
    },
    {
      "name": "Phase 3 — OIDC",
      "item": [
        {
          "name": "OIDC Discovery",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/.well-known/openid-configuration",
            "description": "Phase 3 — OIDC Provider Metadata (RFC 8414). Returns issuer, endpoints, supported algorithms."
          }
        },
        {
          "name": "JWKS",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/.well-known/jwks.json",
            "description": "Phase 3 — JSON Web Key Set (RFC 7517). RSA public keys with kid, use=sig, alg=RS256."
          }
        },
        {
          "name": "JWKS Key Rotation",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/.well-known/jwks.json",
            "description": "Phase 3 — Generates a new RSA key pair, adds it to the keystore, returns the new kid. Old keys remain valid for token validation."
          }
        },
        {
          "name": "Token (Auth Code + ID Token)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/oauth2/token",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "authorization_code" },
                { "key": "code", "value": "AUTH_CODE" },
                { "key": "code_verifier", "value": "{{code_verifier}}" },
                { "key": "redirect_uri", "value": "{{redirect_uri}}" },
                { "key": "client_id", "value": "{{client_id}}" }
              ]
            },
            "description": "Phase 3 — Auth code exchange also returns id_token (RS256 JWT) alongside access_token and refresh_token."
          }
        },
        {
          "name": "UserInfo",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/userinfo",
            "header": [
              { "key": "Authorization", "value": "Bearer ACCESS_TOKEN" }
            ],
            "description": "Phase 3 — OIDC claims endpoint (OIDC Core 1.0 §5.3). Returns sub, scope, and scope-driven claims."
          }
        }
      ]
    },
    {
      "name": "Phase 4 — Token Lifecycle",
      "item": [
        {
          "name": "Token Introspection",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/oauth2/introspect",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "token", "value": "ACCESS_TOKEN", "description": "Token to introspect (jti lookup)" },
                { "key": "token_type_hint", "value": "access_token", "description": "Optional hint — access_token or refresh_token" }
              ]
            },
            "description": "Phase 4 — RFC 7662 Token Introspection. Returns {active: true, sub, client_id, scope, exp, iat} or {active: false}."
          }
        },
        {
          "name": "Token Revocation",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/oauth2/revoke",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "token", "value": "TOKEN_TO_REVOKE", "description": "Token to revoke" },
                { "key": "token_type_hint", "value": "access_token", "description": "Optional hint — access_token or refresh_token" }
              ]
            },
            "description": "Phase 4 — RFC 7009 Token Revocation. Always returns 200 OK (per spec, even if token invalid). Revoking a refresh token also revokes its paired access token (token family)."
          }
        }
      ]
    },
    {
      "name": "Phase 5 — Admin UI",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/login",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "admin", "description": "Test user: admin, user1, alice" },
                { "key": "password", "value": "admin123", "description": "Passwords: admin123, user1pass, alicepass" }
              ]
            },
            "description": "Phase 5 — Authenticate user, returns login_token (Redis, 10min TTL). Test: admin/admin123, user1/user1pass, alice/alicepass."
          }
        },
        {
          "name": "Admin — List Clients",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/clients?page=0&size=20",
            "header": [
              { "key": "Authorization", "value": "Bearer ACCESS_TOKEN", "description": "Bearer token from Phase 2/3 auth code flow" }
            ],
            "description": "Phase 5 — List OAuth clients. Requires Bearer token (any valid access token)."
          }
        },
        {
          "name": "Admin — List Audit Events",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/audit?page=0&size=50",
            "header": [
              { "key": "Authorization", "value": "Bearer ACCESS_TOKEN", "description": "Bearer token from Phase 2/3 auth code flow" }
            ],
            "description": "Phase 5 — List audit events with pagination. Supports ?eventType= filter. Requires Bearer token."
          }
        },
        {
          "name": "Admin — List Users (placeholder)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/users",
            "header": [
              { "key": "Authorization", "value": "Bearer ACCESS_TOKEN", "description": "Bearer token from Phase 2/3 auth code flow" }
            ],
            "description": "Phase 5 — Returns placeholder user list. Full SCIM /Users in Phase 6."
          }
        }
      ]
    },
    {
      "name": "Phase 4 — SCIM 2.0 (planned)",
      "item": [
        {
          "name": "Create User (Joinee)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/scim/v2/Users",
            "header": [
              { "key": "Content-Type", "value": "application/scim+json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schemas\": [\"urn:ietf:params:scim:schemas:core:2.0:User\"],\n  \"userName\": \"john.doe\",\n  \"name\": { \"givenName\": \"John\", \"familyName\": \"Doe\" },\n  \"emails\": [{ \"value\": \"john.doe@example.com\", \"primary\": true }],\n  \"active\": true\n}"
            },
            "description": "Phase 5 — SCIM joiner flow. Creates user account."
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/scim/v2/Users",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "description": "Phase 5 — List all SCIM users with optional filtering."
          }
        },
        {
          "name": "Create Group",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/scim/v2/Groups",
            "header": [
              { "key": "Content-Type", "value": "application/scim+json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schemas\": [\"urn:ietf:params:scim:schemas:core:2.0:Group\"],\n  \"displayName\": \"Engineering\",\n  \"members\": [{ \"value\": \"{{user_id}}\" }]\n}"
            },
            "description": "Phase 5 — Create a SCIM group."
          }
        },
        {
          "name": "Patch Group (Modify Membership)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/scim/v2/Groups/{{group_id}}",
            "header": [
              { "key": "Content-Type", "value": "application/scim+json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schemas\": [\"urn:ietf:params:scim:api:messages:2.0:PatchOp\"],\n  \"Operations\": [\n    { \"op\": \"add\", \"path\": \"members\", \"value\": [{ \"value\": \"{{user_id}}\" }] }\n  ]\n}"
            },
            "description": "Phase 5 — RFC 7644 §4.3 PATCH. Add or remove group members."
          }
        }
      ]
    },
    {
      "name": "Phase 6 — MFA (planned)",
      "item": [
        {
          "name": "TOTP Setup (Begin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/mfa/totp/setup",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "description": "Phase 6 — Generate TOTP secret and provisioning URI. Returns QR code payload."
          }
        },
        {
          "name": "TOTP Verify",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/mfa/totp/verify",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"123456\",\n  \"secret_encrypted\": \"BASE64_ENCODED_SECRET\"\n}"
            },
            "description": "Phase 6 — Verify TOTP code. On success, TotpCredential.verified=true."
          }
        },
        {
          "name": "WebAuthn Register (Begin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/webauthn/register/begin",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "description": "Phase 6 — Generate WebAuthn registration challenge and options."
          }
        },
        {
          "name": "WebAuthn Register (Complete)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/webauthn/register/complete",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credential\": {\n    \"id\": \"BASE64_CREDENTIAL_ID\",\n    \"rawId\": \"BASE64_RAW_CREDENTIAL_ID\",\n    \"response\": {\n      \"attestationObject\": \"BASE64_ATTESTATION_OBJECT\",\n      \"clientDataJSON\": \"BASE64_CLIENT_DATA_JSON\"\n    },\n    \"type\": \"public-key\"\n  },\n  \"challenge\": \"CHALLENGE_FROM_BEGIN\"\n}"
            },
            "description": "Phase 6 — Store WebAuthn credential. WebAuthnCredential record created."
          }
        },
        {
          "name": "WebAuthn Authenticate (Begin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/webauthn/authenticate/begin",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "description": "Phase 6 — Generate WebAuthn authentication assertion challenge."
          }
        },
        {
          "name": "WebAuthn Authenticate (Complete)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/webauthn/authenticate/complete",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credential\": {\n    \"id\": \"BASE64_CREDENTIAL_ID\",\n    \"rawId\": \"BASE64_RAW_CREDENTIAL_ID\",\n    \"response\": {\n      \"authenticatorData\": \"BASE64_AUTHENTICATOR_DATA\",\n      \"clientDataJSON\": \"BASE64_CLIENT_DATA_JSON\",\n      \"signature\": \"BASE64_SIGNATURE\",\n      \"userHandle\": \"BASE64_USER_HANDLE\"\n    },\n    \"type\": \"public-key\"\n  },\n  \"challenge\": \"CHALLENGE_FROM_BEGIN\"\n}"
            },
            "description": "Phase 6 — Verify WebAuthn assertion. sign_count incremented on success."
          }
        }
      ]
    },
    {
      "name": "Phase 3 — Device Authorization Grant (planned)",
      "item": [
        {
          "name": "Device Authorization Start",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/device_authorization",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "client_id", "value": "{{client_id}}" },
                { "key": "scope", "value": "openid profile" }
              ]
            },
            "description": "Phase 3 — RFC 8628. Returns device_code, user_code, verification_uri. User code expires in 10min."
          }
        },
        {
          "name": "Device Approval Page",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/device?user_code=USER_CODE",
              "host": ["{{baseUrl}}"],
              "path": ["device"],
              "query": [
                { "key": "user_code", "value": "USER_CODE", "description": "User code from device_authorization response" }
              ]
            },
            "description": "Phase 3 — Human approval page for device flow. User enters user_code and approves."
          }
        },
        {
          "name": "Token (Device Code Polling)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/oauth2/token",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "urn:ietf:params:oauth:grant-type:device_code" },
                { "key": "device_code", "value": "DEVICE_CODE" },
                { "key": "client_id", "value": "{{client_id}}" }
              ]
            },
            "description": "Phase 3 — RFC 8628. Poll for device code approval. Returns authorization_pending until approved, then issues tokens. Rate limited."
          }
        }
      ]
    },
    {
      "name": "Phase 4 — SAML 2.0 (planned)",
      "item": [
        {
          "name": "SP Metadata",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/saml/metadata",
            "description": "Phase 4 — SAML SP metadata XML (signed). Register this with your IdP."
          }
        },
        {
          "name": "Initiate SSO",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/saml/initiate?client_id={{client_id}}&redirect_uri={{redirect_uri}}",
              "host": ["{{baseUrl}}"],
              "path": ["saml", "initiate"],
              "query": [
                { "key": "client_id", "value": "{{client_id}}" },
                { "key": "redirect_uri", "value": "{{redirect_uri}}" }
              ]
            },
            "description": "Phase 4 — SAML SP-initiated SSO. Redirects to IdP with signed AuthnRequest."
          }
        },
        {
          "name": "ACS (Assertion Consumer Service)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/saml/acs",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "SAMLResponse", "value": "BASE64_ENCODED_SAML_RESPONSE" },
                { "key": "RelayState", "value": "optional-state" }
              ]
            },
            "description": "Phase 4 — Receives SAMLResponse from IdP. Validates signature, audience, conditions, in-response-to. Maps claims to OIDC tokens."
          }
        }
      ]
    }
  ]
}
